{
  "expo": {
    "name": "SakayNa",
    "slug": "SakayNa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_app.png",
    "userInterfaceStyle": "light",
    "scheme": "sakayna",
    "splash": {
      "image": "./assets/icon_app.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lemera.sakayna",
      "config": {
        "googleMapsApiKey": "AIzaSyCPuMCVa_9EB832dXm1P0t2Nv1UqBYQgws"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to show your position on the map, set pickup points, and improve ride booking.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lemera.sakayna",
      "versionCode": 17,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_app.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCPuMCVa_9EB832dXm1P0t2Nv1UqBYQgws"
        }
      }
    },
    "web": {
      "favicon": "./assets/sakayna_icon.png"
    },
    "extra": {
      "GOOGLE_API_KEY": "AIzaSyCPuMCVa_9EB832dXm1P0t2Nv1UqBYQgws",
      "eas": {
        "projectId": "d93903f7-9c78-477d-b505-0582532d4fdf"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SakayNa to use your location to show your position on the map, suggest pickup points, and improve ride booking.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E97A3E",
          "sounds": [
            "./assets/sounds/new_booking.wav"
          ]
        }
      ],
      "expo-font",
      "expo-asset"
    ]
  }
}
