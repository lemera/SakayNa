// AIzaSyCPuMCVa_9EB832dXm1P0t2Nv1UqBYQgws
{
  "expo": {
    "name": "SakayNa",
    "slug": "SakayNa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/iconss.png",
    "userInterfaceStyle": "light",
    "scheme": "sakayna",

    "splash": {
      "image": "./assets/sakayna_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00000000"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lemera.sakayna",
      "config": {
        "googleMapsApiKey": "AIzaSyCPuMCVa_9EB832dXm1P0t2Nv1UqBYQgws"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to track rides and show your position on map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to location to track rides and show your position on map.",
        "UIBackgroundModes": ["location"]
      }
    },

    "android": {
      "package": "com.lemera.sakayna",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/sakayna_icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCPuMCVa_9EB832dXm1P0t2Nv1UqBYQgws"
        }
      }
    },

    "web": {
      "favicon": "./assets/sakayna_icon.png"
    },

    "extra": {
      "GOOGLE_API_KEY": "AIzaSyCPuMCVa_9EB832dXm1P0t2Nv1UqBYQgws",
      "eas": {
        "projectId": "2c53eff2-d71b-44a1-b9ac-cfc13330d935"
      }
    },

    "plugins": [
      "expo-secure-store",

      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SakayNa to use your location to track rides."
        }
      ],

      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E97A3E",
          "sounds": ["./assets/sounds/new_booking.wav"]
        }
      ],

      "expo-font",
      "expo-asset"
    ]
  }
}